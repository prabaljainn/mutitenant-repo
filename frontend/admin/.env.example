# ──────────────────────────────────────────────────────────────────
# Backend (Spring Boot platform) base URL — proxied via next.config.ts.
# Leave unset to talk to a same-origin backend (production behind Traefik).
# ──────────────────────────────────────────────────────────────────
PLATFORM_API_BASE=http://localhost:8080

# ──────────────────────────────────────────────────────────────────
# Build-time public toggles
# ──────────────────────────────────────────────────────────────────
# Show the Tweaks panel (theme/density/sidebar/table) in the UI. Strictly dev.
NEXT_PUBLIC_ENABLE_TWEAKS=true

# Use Next.js Route Handler mocks for endpoints the Spring backend hasn't
# implemented yet. When false, calls hit the real backend and return 501-
# style errors that the UI surfaces inline.
NEXT_PUBLIC_USE_MOCKS=true
