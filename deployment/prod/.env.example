# Production environment template.
# Copy to `.env` next to docker-compose.yml and fill in real values.
# DO NOT commit the populated .env file — it carries every secret the
# platform needs.

# ─────────────────────────────────────────────────────────────────────
# Public hostname
# ─────────────────────────────────────────────────────────────────────
# The FQDN the platform answers on. Must point at this host's public IP
# (A or AAAA record) for Let's Encrypt's TLS-ALPN-01 challenge to work.
PLATFORM_HOST=api.example.com
# Email for the Let's Encrypt account — receives expiry notices.
LETSENCRYPT_EMAIL=ops@example.com

# ─────────────────────────────────────────────────────────────────────
# Platform image
# ─────────────────────────────────────────────────────────────────────
# Pulled from GHCR. Use `latest` for "follow main" or a sha-/v-tag to
# pin a specific build. For zero-downtime updates pin a tag and bump
# it in this file.
PLATFORM_IMAGE=ghcr.io/<owner>/<repo>/platform
PLATFORM_IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────
# MongoDB — root user + app user
# ─────────────────────────────────────────────────────────────────────
# The rs0 internal-auth keyfile is generated automatically on first
# boot by the `mongo-keyfile-init` service into the `mongodb_keyfile`
# docker volume — no manual `gen-mongo-keyfile.sh` step is required.
# The volume persists across `down/up`; only `down -v` rotates it
# (which also wipes mongodb_data, so the replica set stays consistent).
#
# Root creds below are used only by mongo-init to bootstrap the app
# user. Rotate any time; the app never uses them at runtime.
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=replace-with-long-random-string

# App-side credentials. The platform connects as this user.
# Generate with `openssl rand -base64 32`.
MONGO_APP_USERNAME=platform
MONGO_APP_PASSWORD=replace-with-long-random-string

# ─────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────
# `openssl rand -base64 32`
REDIS_PASSWORD=replace-with-long-random-string

# ─────────────────────────────────────────────────────────────────────
# SMTP — outbound email for invites and password resets
# ─────────────────────────────────────────────────────────────────────
# Any reachable SMTP relay. Examples: SendGrid (smtp.sendgrid.net:587),
# Mailgun, AWS SES, Postmark. Local Postfix works too.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=replace-with-smtp-credential

# Visible "From" line on outgoing emails. Must be a domain you control
# and have SPF/DKIM configured for, or delivery will land in spam.
PLATFORM_EMAIL_FROM=noreply@example.com
PLATFORM_EMAIL_REPLY_TO=support@example.com

# ─────────────────────────────────────────────────────────────────────
# JWT keys
# ─────────────────────────────────────────────────────────────────────
# Generate with: ../../scripts/gen-jwt-keys.sh
# The script drops the key files into ./secrets/jwt/ and prints the kid.
# Copy the kid here.
PLATFORM_JWT_KEY_ID=prod-replace-after-running-gen-jwt-keys

# ─────────────────────────────────────────────────────────────────────
# First-boot bootstrap operator
# ─────────────────────────────────────────────────────────────────────
# Created automatically on first startup if no operator exists yet.
# Use it to log into /admin once, then create real operators via the
# admin API and rotate this password (or unset these vars and restart).
BOOTSTRAP_OPERATOR_EMAIL=admin@example.com
BOOTSTRAP_OPERATOR_PASSWORD=replace-with-strong-password
