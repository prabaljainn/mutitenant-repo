# ============================================================================
# Local development environment variables.
# Copy this file to deployment/.env and edit as needed.
#   cp deployment/.env.example deployment/.env
# ============================================================================

# ---------------------------------------------------------------------------
# Versions — pinned so every contributor runs the same stack.
# ---------------------------------------------------------------------------
# MongoDB: 8.0 is the current LTS (supported until ~Oct 2027).
# Set to 8.3 if you want the rapid-release line (shorter support window).
MONGO_VERSION=8.0

# Redis 7.4 alpine is the current stable line.
REDIS_VERSION=7.4-alpine

# ---------------------------------------------------------------------------
# Service ports — change only if you have local conflicts.
# ---------------------------------------------------------------------------
MONGO_PORT=27017
REDIS_PORT=6379
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
TRAEFIK_DASHBOARD_PORT=8090

# ---------------------------------------------------------------------------
# Spring Boot app — used by scripts/run-app.sh
# ---------------------------------------------------------------------------
APP_PORT=8080
APP_DEBUG_PORT=5005
SPRING_PROFILES_ACTIVE=dev

# JVM tuning for local dev. ZGC + generational ZGC are recommended on Java 21+.
# --enable-preview stays on for now since some APIs we use (Scoped Values
# variants) are still preview-flagged in some Java 25 builds.
JAVA_OPTS="-Xms256m -Xmx1g -XX:+UseZGC -XX:+ZGenerational --enable-preview"
