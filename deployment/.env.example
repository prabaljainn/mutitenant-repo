# ─────────────────────────────────────────────
# Deployment Environment Configuration
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# MongoDB
MONGO_PORT=27017
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=changeme_in_production
MONGO_DB_NAME=multitenant_platform
MONGO_APP_USERNAME=platform_app
MONGO_APP_PASSWORD=changeme_in_production

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_production

# Mailhog (dev only)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
